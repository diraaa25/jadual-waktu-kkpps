{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firebase-rules.json",
      "server.ps1",
      "Data_Senarai_Nama.xlsx",
      "Template_Muat_Naik_Subjek.csv",
      ".git",
      ".gitignore",
      "node_modules",
      "*.md"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/pelajar",
        "destination": "/Pelajar.html"
      },
      {
        "source": "/pensyarah",
        "destination": "/Pensyarah.html"
      },
      {
        "source": "/programmer",
        "destination": "/Programmer.html"
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  },
  "database": {
    "rules": "firebase-rules.json"
  }
}
